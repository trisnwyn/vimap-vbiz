# VinMap-Biz — Environment Variables
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments — do not commit .env.local to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key for AI forest-risk analysis (llama-3.3-70b-versatile model)
# Free tier: 14,400 requests/day · 500 requests/minute
# Get yours at https://console.groq.com
GROQ_API_KEY=

# ── Clerk — Authentication ─────────────────────────────────────────────────────
# Create a free app at https://dashboard.clerk.com
# Copy from: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_

# Clerk redirect URLs (default values work for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Supabase — Database ────────────────────────────────────────────────────────
# Create a free project at https://supabase.com
# Copy from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe — Payments ─────────────────────────────────────────────────────────
# Create a free account at https://dashboard.stripe.com
# Use test keys (pk_test_ / sk_test_) for development
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Webhook secret — generate with: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_

# Price IDs — create products in Stripe Dashboard → Products, then paste the price IDs here
STRIPE_PRICE_ANALYST_MONTHLY=price_
STRIPE_PRICE_ANALYST_YEARLY=price_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_YEARLY=price_

# ── Optional — Enhanced live data sources ─────────────────────────────────────
# Without these keys the app still works, but falls back to modeled/procedural data.
# Each key is free for non-commercial / research use.

# Global Forest Watch Data API
# Enables real province-level tree cover loss from Hansen/UMD/Google/USGS/NASA dataset
# Register at https://www.globalforestwatch.org/help/developers/
GFW_API_KEY=

# NASA FIRMS fire hotspot map key
# Enables live VIIRS/MODIS fire hotspot data for Vietnam
# Register at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# ── Notes ─────────────────────────────────────────────────────────────────────
# Weather data: Open-Meteo (ERA5 archive) — no key required
# Soil data:    ISRIC SoilGrids v2.0 — no key required
# Boundaries:   Public GeoJSON via GitHub CDN — no key required
# World Bank forestry indicators — no key required
